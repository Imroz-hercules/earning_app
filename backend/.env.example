FLASK_APP=wsgi.py
FLASK_ENV=production
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# Supabase Storage. Required for production document/proof uploads.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=taskhub

# Optional first admin seeding command uses these values.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=TaskHub Admin
